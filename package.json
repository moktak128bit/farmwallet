{
  "name": "farmwallet-web",
  "version": "4.1.0",
  "private": true,
  "scripts": {
    "predev": "npm run -s check-text && node scripts/generate-kr-names.mjs",
    "prebuild": "npm run -s check-text && node scripts/generate-kr-names.mjs",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "ticker:gen-names": "node scripts/generate-kr-names.mjs",
    "lint": "npm run -s ticker:gen-names && tsc --noEmit && eslint src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:smoke": "node scripts/smoke-test.mjs",
    "ci": "npm run -s check-text && npm run -s lint && npm run -s build && npm run -s test:smoke",
    "check-text": "node scripts/check-text-integrity.mjs",
    "check-text:report": "node scripts/check-text-integrity.mjs --report",
    "check-text:update-baseline": "node scripts/check-text-integrity.mjs --update-baseline"
  },
  "dependencies": {
    "lucide-react": "^0.562.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.6.0",
    "recharts": "^3.6.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.19.25",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react-swc": "^3.7.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jsdom": "^29.0.2",
    "knip": "^5.87.0",
    "prettier": "^3.8.1",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.3",
    "workbox-window": "^7.4.0"
  }
}
