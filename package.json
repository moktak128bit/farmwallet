{
  "name": "farmwallet-web",
  "version": "3.9.0",
  "private": true,
  "scripts": {
    "predev": "npm run -s check-text && node scripts/generate-kr-names.mjs",
    "prebuild": "npm run -s check-text && node scripts/generate-kr-names.mjs",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "ticker:gen-names": "node scripts/generate-kr-names.mjs",
    "lint": "npm run -s ticker:gen-names && tsc --noEmit",
    "test": "npm run test:smoke",
    "test:smoke": "node scripts/smoke-test.mjs",
    "ci": "npm run -s check-text && npm run -s lint && npm run -s build && npm run -s test:smoke",
    "check-text": "node scripts/check-text-integrity.mjs",
    "check-text:report": "node scripts/check-text-integrity.mjs --report",
    "check-text:update-baseline": "node scripts/check-text-integrity.mjs --update-baseline"
  },
  "dependencies": {
    "lucide-react": "^0.562.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.6.0",
    "recharts": "^3.6.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/node": "^20.19.25",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react-swc": "^3.7.0",
    "knip": "^5.87.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.0"
  }
}
